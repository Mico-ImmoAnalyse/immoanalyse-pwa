<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ImmoAnalyse v6</title>
  <meta name="theme-color" content="#000000">
  <meta name="color-scheme" content="dark">

  <style>
    :root {
      --bg: #0f1012;
      --bg-section: #18191c;
      --bg-card: #202226;
      --text: #e7e7ea;
      --muted: #a0a0a8;
      --accent: #4da3ff;
      --border: #2a2c31;
      --badge-bg: #2b2d33;
      --badge-border: #555861;
      --premium: #4da3ff;
      --safe: #00c853;
      --tendu: #ff9800;
      --critique: #ff5252;
    }
    .light {
      --bg: #f5f6f8;
      --bg-section: #ffffff;
      --bg-card: #f3f4f7;
      --text: #22252b;
      --muted: #6b6f78;
      --accent: #0077cc;
      --border: #d0d3dc;
      --badge-bg: #e4e6ee;
      --badge-border: #b5b8c3;
    }
    body {
      margin: 0;
      padding: 0;
      background: var(--bg);
      color: var(--text);
      font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      transition: background 0.25s ease, color 0.25s ease;
    }
    h1 { text-align: center; margin: 10px 0 6px 0; color: var(--accent); font-size: 22px; }
    h2 { margin: 8px 0 6px 0; color: var(--accent); font-size: 18px; }
    h3 { margin: 6px 0 4px 0; color: var(--accent); font-size: 15px; }
    label { font-size: 13px; }

    .container {
      width: 94%;
      max-width: 560px;
      margin: 10px auto 20px auto;
    }

    input, select {
      width: 100%;
      padding: 7px 8px;
      margin: 3px 0 9px 0;
      border-radius: 6px;
      border: 1px solid var(--border);
      background: #1b1d22;
      color: var(--text);
      font-size: 13px;
      box-sizing: border-box;
    }
    .light input,
    .light select {
      background: #ffffff;
    }
    input::placeholder {
      color: var(--muted);
    }

    button {
      width: 100%;
      padding: 11px;
      background: var(--accent);
      border: none;
      border-radius: 6px;
      color: #000;
      font-weight: 600;
      cursor: pointer;
      margin-top: 10px;
      font-size: 14px;
    }
    button:hover { background: #6bb4ff; }

    .secondary {
      background: transparent;
      border: 1px solid var(--accent);
      color: var(--accent);
      padding: 6px 12px;
      border-radius: 6px;
      cursor: pointer;
      width: auto;
      font-size: 13px;
    }
    .secondary:hover { background: var(--accent); color: #000; }

    table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 10px;
      font-size: 13px;
    }
    th, td {
      border: 1px solid var(--border);
      padding: 6px 4px;
      text-align: center;
    }
    th {
      background: var(--bg-card);
      font-weight: 600;
    }

    .section {
      background: var(--bg-section);
      border: 1px solid var(--border);
      padding: 10px;
      border-radius: 10px;
      margin: 10px auto;
      box-shadow: 0 0 8px rgba(0,0,0,0.35);
    }
    .grid-2 {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 6px;
    }
    .grid-3 {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 6px;
    }
    @media (max-width: 800px) {
      .grid-2, .grid-3 { grid-template-columns: 1fr; }
    }

    .header-block { text-align: center; }
    .subtitle {
      color: var(--muted);
      margin-top: -4px;
      margin-bottom: 10px;
      font-size: 12px;
    }
    .card {
      background: var(--bg-card);
      padding: 8px;
      border-radius: 8px;
      border: 1px solid var(--border);
    }
    .big-number { font-size: 22px; font-weight: 700; color: var(--accent); }
    .note { font-size: 11px; color: var(--muted); }

    .header-buttons {
      display: flex;
      justify-content: center;
      gap: 8px;
      margin-bottom: 6px;
    }

    .theme-toggle {
      position: fixed;
      top: 14px;
      right: 14px;
      z-index: 999;
    }
    .theme-toggle button {
      background: var(--bg-section);
      color: var(--text);
      border: 1px solid var(--border);
      padding: 8px 11px;
      border-radius: 50%;
      font-size: 17px;
      cursor: pointer;
      width: auto;
    }

    .guide-panel {
      position: fixed;
      top: 0;
      right: -380px;
      width: 360px;
      height: 100vh;
      overflow-y: auto;
      background: var(--bg-section);
      border-left: 1px solid var(--border);
      padding: 10px 12px;
      transition: right 0.3s ease;
      z-index: 9999;
      box-shadow: -4px 0 12px rgba(0,0,0,0.5);
      display: flex;
      flex-direction: column;
    }
    .guide-panel.open { right: 0; }
    .guide-content {
      flex: 1;
      min-height: 100%;
      width: 100%;
      display: flex;
      flex-direction: column;
    }
    .guide-content h2 { margin-top: 0; font-size: 18px; }
    .guide-content p { margin-bottom: 10px; line-height: 1.4; font-size: 13px; }
    .guide-panel::-webkit-scrollbar { width: 6px; }
    .guide-panel::-webkit-scrollbar-thumb {
      background: var(--accent);
      border-radius: 10px;
    }

    .guide-tabs {
      display: flex;
      gap: 6px;
      margin-bottom: 12px;
      flex-wrap: wrap;
    }
    .guide-tab {
      padding: 6px 12px;
      border-radius: 6px;
      background: var(--bg-card);
      border: 1px solid var(--border);
      cursor: pointer;
      font-size: 13px;
      color: var(--text);
      user-select: none;
    }
    .guide-tab.active {
      background: var(--accent);
      color: #000;
      border-color: var(--accent);
    }
    .guide-section {
      display: none;
      animation: fadeIn 0.25s ease;
    }
    .guide-section.active { display: block; }
    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(4px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .accordion {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 6px;
      margin-bottom: 8px;
    }
    .accordion-header {
      padding: 8px;
      cursor: pointer;
      font-size: 14px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .accordion-header:hover { background: var(--bg-section); }
    .accordion-content {
      display: none;
      padding: 8px;
      font-size: 13px;
      color: var(--muted);
      border-top: 1px solid var(--border);
    }
    .accordion.open .accordion-content { display: block; }
    .accordion-arrow { font-size: 12px; opacity: 0.7; }

    .garanties-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 6px;
      align-items: center;
    }
    .garanties-grid label {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 13px;
    }
    .garanties-grid input[type="checkbox"] {
      width: auto;
      margin: 0;
    }
    .badge-pourcent {
      display: inline-flex;
      align-items: center;
      padding: 1px 6px;
      border-radius: 999px;
      background: var(--badge-bg);
      border: 1px solid var(--badge-border);
      font-size: 11px;
      color: var(--muted);
    }

    .risque-premium { color: var(--premium); font-weight: 600; }
    .risque-safe { color: var(--safe); font-weight: 600; }
    .risque-tendu { color: var(--tendu); font-weight: 600; }
    .risque-critique { color: var(--critique); font-weight: 600; }

    .tickets-cell {
      display: flex;
      flex-direction: column;
      gap: 2px;
    }
    .tickets-main { font-weight: 600; }
    .tickets-mise { font-size: 11px; color: var(--muted); }
  </style>
</head>
<body>
  <div class="theme-toggle">
    <button id="toggleTheme">🌙</button>
  </div>

  <!-- GUIDE PANEL -->
  <div id="guidePanel" class="guide-panel">
    <div class="guide-content">
      <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:8px;">
        <h2>Guide ImmoAnalyse</h2>
        <button class="secondary" onclick="closeGuide()">Fermer</button>
      </div>

      <div class="guide-tabs">
        <div class="guide-tab active" data-tab="crit">Critères</div>
        <div class="guide-tab" data-tab="garanties">Garanties</div>
        <div class="guide-tab" data-tab="alertes">Alertes</div>
        <div class="guide-tab" data-tab="exemples">Exemples</div>
        <div class="guide-tab" data-tab="opt">Optimisation</div>
        <div class="guide-tab" data-tab="lecture">Lecture rapide</div>
        <div class="guide-tab" data-tab="faq">FAQ</div>
      </div>

      <div class="guide-section active" id="crit">
        <div class="accordion">
          <div class="accordion-header">LTV — Loan To Value 🟢🟠🔴 <span class="accordion-arrow">▼</span></div>
          <div class="accordion-content">
            <b>Définition :</b> Dette / Valeur du bien.<br><br>
            🟢 &lt; 60% — Très sécurisé<br>
            🟠 60–85% — Zone de vigilance<br>
            🔴 &gt; 85% — Risque élevé<br><br>
            Un LTV élevé fragilise la capacité de remboursement en cas de revente.
          </div>
        </div>
        <div class="accordion">
          <div class="accordion-header">LTA — Loan To Assets 🟢🟠🔴 <span class="accordion-arrow">▼</span></div>
          <div class="accordion-content">
            <b>Définition :</b> Dette / Actifs totaux.<br><br>
            🟢 &lt; 70% — Structure solide<br>
            🟠 70–85% — Endettement à surveiller<br>
            🔴 &gt; 85% — Structure fragile<br><br>
            Mesure la solidité financière globale du projet.
          </div>
        </div>
        <div class="accordion">
          <div class="accordion-header">LTC — Loan To Cost 🟢🟠🔴 <span class="accordion-arrow">▼</span></div>
          <div class="accordion-content">
            <b>Définition :</b> Dette / Coût total du projet.<br><br>
            🟢 &lt; 70% — Excellent<br>
            🟠 70–85% — Acceptable<br>
            🔴 &gt; 85% — Risque de dépassement<br><br>
            Un LTC élevé indique un projet trop dépendant de la dette.
          </div>
        </div>
        <div class="accordion">
          <div class="accordion-header">Marge (MDB) 🟢🟠🔴 <span class="accordion-arrow">▼</span></div>
          <div class="accordion-content">
            🟢 &gt; 20% — Très bon<br>
            🟠 10–20% — Correct<br>
            🔴 &lt; 10% — Risque de perte<br><br>
            La marge est le coussin de sécurité du marchand de biens.
          </div>
        </div>
        <div class="accordion">
          <div class="accordion-header">Pré‑commercialisation 🟢🟠🔴 <span class="accordion-arrow">▼</span></div>
          <div class="accordion-content">
            🟢 &gt; 50% — Très sécurisé<br>
            🟠 30–50% — À surveiller<br>
            🔴 &lt; 30% — Risque commercial<br><br>
            Plus la pré‑commercialisation est élevée, plus le risque d’invendus diminue.
          </div>
        </div>
        <div class="accordion">
          <div class="accordion-header">Liquidité (1–10) 🟢🟠🔴 <span class="accordion-arrow">▼</span></div>
          <div class="accordion-content">
            🟢 8–10 — Marché très liquide<br>
            🟠 5–7 — Liquide<br>
            🔴 1–4 — Revente difficile<br><br>
            La liquidité conditionne la capacité à sortir rapidement du projet.
          </div>
        </div>
      </div>

      <div class="guide-section" id="garanties">
        <div class="accordion">
          <div class="accordion-header">Pondération dynamique des garanties <span class="accordion-arrow">▼</span></div>
          <div class="accordion-content">
            <b>Principe :</b><br>
            La pondération n’est plus fixe. Elle dépend de :<br>
            – la nature de la garantie (poids de base)<br>
            – le taux de couverture (%)<br>
            – la caution personnelle (convertie en %)<br><br>
            Exemple :<br>
            Hypothèque (poids 1.0) × couverture 80% → 80<br>
            Nantissement (poids 0.6) × couverture 50% → 30<br>
            Caution personnelle → convertie en % puis × 0.4<br><br>
            La pondération finale est intégrée dans : LTV net, score global, sécurité globale, ticket IA.
          </div>
        </div>
        <div class="accordion">
          <div class="accordion-header">Garanties fortes / moyennes / faibles <span class="accordion-arrow">▼</span></div>
          <div class="accordion-content">
            🟢 Garanties très fortes : Fiducie, G1D, Hypothèque 1er rang<br>
            🟠 Garanties moyennes : Nantissement<br>
            🔴 Garanties faibles : Caution personnelle<br><br>
            Une couverture &gt; 100% déclenche une alerte, mais peut être acceptée si elle reflète une sur‑garantie.
          </div>
        </div>
      </div>

      <div class="guide-section" id="alertes">
        <p>Le moteur détecte automatiquement les incohérences et risques :</p>
        <div class="accordion">
          <div class="accordion-header">Alertes financières <span class="accordion-arrow">▼</span></div>
          <div class="accordion-content">
            – LTV trop élevé<br>
            – LTA incohérent<br>
            – LTC &gt; 85%<br>
            – Marge insuffisante<br>
            – Mise trop faible<br>
            – Couverture de garanties incohérente (&gt; 100% ou insuffisante)
          </div>
        </div>
        <div class="accordion">
          <div class="accordion-header">Alertes commerciales <span class="accordion-arrow">▼</span></div>
          <div class="accordion-content">
            – Pré‑commercialisation trop faible<br>
            – Liquidité insuffisante<br>
            – Risque de stock invendu
          </div>
        </div>
        <div class="accordion">
          <div class="accordion-header">Alertes structurelles <span class="accordion-arrow">▼</span></div>
          <div class="accordion-content">
            – Endettement global trop élevé<br>
            – Absence de garanties fortes<br>
            – Ratio incohérent avec le type de projet (MDB / LDT)
          </div>
        </div>
      </div>

      <div class="guide-section" id="exemples">
        <div class="accordion">
          <div class="accordion-header">Exemple MDB <span class="accordion-arrow">▼</span></div>
          <div class="accordion-content">
            LTV = 88% 🔴<br>
            Marge = 12% 🟠<br>
            Liquidité = 6 🟠<br>
            Garanties = Caution seule 🔴<br><br>
            → Statut : TENDU<br>
            → Ticket IA : 0–250 €<br>
            → Reco : réduire la dette + ajouter une garantie forte + augmenter la mise.
          </div>
        </div>
        <div class="accordion">
          <div class="accordion-header">Exemple LDT <span class="accordion-arrow">▼</span></div>
          <div class="accordion-content">
            LTV = 72% 🟠<br>
            Liquidité = 8 🟢<br>
            Pré‑Comm = 55% 🟢<br>
            Garanties : Hypothèque 80% + Caution 50k€ 🟢<br><br>
            → Statut : SAFE<br>
            → Ticket IA : 250–500 €<br>
            → Reco : optimiser les charges + sécuriser la saison basse.
          </div>
        </div>
      </div>

      <div class="guide-section" id="opt">
        <div class="accordion">
          <div class="accordion-header">Optimiser un projet MDB <span class="accordion-arrow">▼</span></div>
          <div class="accordion-content">
            – viser une marge &gt; 15%<br>
            – réduire le LTV sous 75%<br>
            – sécuriser une garantie forte (Hypothèque / G1D / Fiducie)<br>
            – buffer travaux 10–15%<br>
            – cohérence prix/m²
          </div>
        </div>
        <div class="accordion">
          <div class="accordion-header">Optimiser un projet LDT <span class="accordion-arrow">▼</span></div>
          <div class="accordion-content">
            – analyser le taux d’occupation réel<br>
            – simuler la saison basse<br>
            – vérifier les restrictions locales<br>
            – optimiser les charges récurrentes<br>
            – cibler les zones touristiques liquides
          </div>
        </div>
      </div>

      <div class="guide-section" id="lecture">
        <p><b>Lecture d’un projet en 10 secondes :</b></p>
        – LTV : si &gt; 85% → danger immédiat<br>
        – Garanties : au moins 1 forte + couverture cohérente<br>
        – Marge (MDB) : &lt; 10% = risque<br>
        – Liquidité : &lt; 5 = marché difficile<br>
        – Statut IA : PREMIUM / SAFE / TENDU / CRITIQUE<br>
        – Ticket IA : cohérent avec ton profil 0–1000 €<br>
        – Mise : cohérente avec le ticket IA proposé
      </div>

      <div class="guide-section" id="faq">
        <div class="accordion">
          <div class="accordion-header">Pourquoi un projet peut être SAFE mais avec un ticket faible ? <span class="accordion-arrow">▼</span></div>
          <div class="accordion-content">
            Parce que le moteur combine score, alertes, garanties et mise.<br>
            Un projet peut être globalement bon mais manquer de sûretés ou de mise suffisante.
          </div>
        </div>
        <div class="accordion">
          <div class="accordion-header">Pourquoi le LTV net diffère du LTV brut ? <span class="accordion-arrow">▼</span></div>
          <div class="accordion-content">
            Le LTV net intègre la pondération dynamique des garanties (type, couverture, caution).<br>
            Plus la couverture est forte, plus le LTV net est réduit.
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="container">
    <div class="section header-block">
      <h1>ImmoAnalyse v6</h1>
      <div class="header-buttons">
        <button class="secondary" onclick="openGuide()">Guide</button>
        <button class="secondary" onclick="exportCSV()">Export CSV</button>
      </div>
      <p class="subtitle">Moteur IA – LTV / LTA / LTC / Marge / Précom / Liquidité / Garanties</p>
      <div class="grid-2">
        <div class="card">
          <h3>Score moyen du portefeuille</h3>
          <p id="scorePortefeuille" class="big-number">0/100</p>
          <p class="note">Aucun projet</p>
        </div>
        <div class="card">
          <h3>Total investi</h3>
          <p id="totalInvesti" class="big-number">0 €</p>
          <p class="note">Capital engagé sur les dossiers audités</p>
        </div>
      </div>
    </div>

    <!-- NOUVEL AUDIT (COMMUN MDB / LDT) -->
    <div class="section">
      <h2>Nouvel audit</h2>
      <label>Type de projet</label>
      <select id="projectType">
        <option value="MDB">MDB – Marchand de biens</option>
        <option value="LDT">LDT – Ligne de trésorerie</option>
      </select>

      <label>Projet</label>
      <input id="nomProjet" type="text" placeholder="Nom du dossier">

      <div class="grid-2">
        <div>
          <label>LTV (%)</label>
          <input id="ltv" type="number" placeholder="Ex : 70">
        </div>
        <div>
          <label>Marge (%)</label>
          <input id="marge" type="number" placeholder="Ex : 15">
        </div>
      </div>

      <div class="grid-2">
        <div>
          <label>Pré-Comm (%)</label>
          <input id="precomm" type="number" placeholder="Ex : 50">
        </div>
        <div>
          <label>Liquidité (1–10)</label>
          <input id="liq" type="number" placeholder="Ex : 7">
        </div>
      </div>
    </div>

    <!-- MODULE LDT -->
    <div class="section" id="sectionLDT" style="display:none;">
      <h2>Ligne de trésorerie (LDT)</h2>
      <div class="grid-2">
        <div>
          <label>Montant recherché (€)</label>
          <input id="ldt_montant" type="number" placeholder="Ex : 1535000">
        </div>
        <div>
          <label>Durée (mois)</label>
          <input id="ldt_duree" type="number" placeholder="Ex : 36">
        </div>
      </div>
      <div class="grid-2">
        <div>
          <label>Taux (%)</label>
          <input id="ldt_taux" type="number" placeholder="Ex : 12">
        </div>
        <div>
          <label>Capacité de remboursement (€/semestre)</label>
          <input id="ldt_capacite" type="number" placeholder="Ex : 270000">
        </div>
      </div>
      <p class="note">
        Ces données permettent d’évaluer la capacité réelle de remboursement, le risque structurel et le ticket IA prudent.
      </p>
    </div>

    <!-- MODULE GARANTIES -->
    <div class="section">
      <h2>Sûretés & Couvertures</h2>

      <h3>Garanties très fortes</h3>
      <div class="garanties-grid">
        <label>
          <input type="checkbox" id="fiducie">
          <span>Fiducie‑Sûreté</span>
          <span class="badge-pourcent">20%</span>
        </label>
        <input id="fiducie_pct" type="number" placeholder="Couverture (%)" disabled>

        <label>
          <input type="checkbox" id="g1d">
          <span>Garantie 1ère demande</span>
          <span class="badge-pourcent">25%</span>
        </label>
        <input id="g1d_pct" type="number" placeholder="Couverture (%)" disabled>

        <label>
          <input type="checkbox" id="hyp1">
          <span>Hypothèque 1er rang</span>
          <span class="badge-pourcent">25%</span>
        </label>
        <input id="hyp1_pct" type="number" placeholder="Couverture (%)" disabled>
      </div>

      <h3>Garanties moyennes</h3>
      <div class="garanties-grid">
        <label>
          <input type="checkbox" id="nantissement">
          <span>Nantissement</span>
          <span class="badge-pourcent">20%</span>
        </label>
        <input id="nantissement_pct" type="number" placeholder="Couverture (%)" disabled>
      </div>

      <h3>Garanties faibles</h3>
      <div class="garanties-grid">
        <label>
          <input type="checkbox" id="caution">
          <span>Caution personnelle</span>
          <span class="badge-pourcent">10%</span>
        </label>
        <input id="caution_eur" type="number" placeholder="Montant (€)" disabled>
      </div>

      <div class="grid-3" style="margin-top:10px;">
        <div>
          <label>LTA (%)</label>
          <input id="lta" type="number" placeholder="Ex : 95">
        </div>
        <div>
          <label>LTC (%)</label>
          <input id="ltc" type="number" placeholder="Ex : 88">
        </div>
        <div>
          <label>Mise (€)</label>
          <input id="mise" type="number" placeholder="Ex : 500">
        </div>
      </div>

      <button onclick="runEngine()">AUDITER & SAUVEGARDER</button>
    </div>

    <!-- TABLEAU PROJETS -->
    <div class="section">
      <h2>Projets audités</h2>
      <table>
        <tr>
          <th>PROJET</th>
          <th>LTV NET</th>
          <th>RISQUE</th>
          <th>TICKETS & MISE</th>
        </tr>
        <tbody id="tableProjets"></tbody>
      </table>
    </div>
  </div>

  <script>
    // THEME
    const toggleBtn = document.getElementById("toggleTheme");
    function applyTheme(theme) {
      if (theme === "light") {
        document.body.classList.add("light");
        toggleBtn.textContent = "🌞";
      } else {
        document.body.classList.remove("light");
        toggleBtn.textContent = "🌙";
      }
    }
    const savedTheme = localStorage.getItem("theme") || "dark";
    applyTheme(savedTheme);
    toggleBtn.addEventListener("click", () => {
      const newTheme = document.body.classList.contains("light") ? "dark" : "light";
      localStorage.setItem("theme", newTheme);
      applyTheme(newTheme);
    });

    // GUIDE
    function openGuide() {
      document.getElementById("guidePanel").classList.add("open");
    }
    function closeGuide() {
      document.getElementById("guidePanel").classList.remove("open");
    }
    document.querySelectorAll(".guide-tab").forEach(tab => {
      tab.addEventListener("click", () => {
        document.querySelectorAll(".guide-tab").forEach(t => t.classList.remove("active"));
        document.querySelectorAll(".guide-section").forEach(s => s.classList.remove("active"));
        tab.classList.add("active");
        document.getElementById(tab.dataset.tab).classList.add("active");
      });
    });
    document.querySelectorAll(".accordion-header").forEach(header => {
      header.addEventListener("click", () => {
        header.parentElement.classList.toggle("open");
      });
    });

    // GARANTIES : activation champs
    function bindGuaranteeToggle(idCheck, idField) {
      const check = document.getElementById(idCheck);
      const field = document.getElementById(idField);
      if (!check || !field) return;
      check.addEventListener("change", () => {
        field.disabled = !check.checked;
        if (!check.checked) field.value = "";
      });
    }
    document.addEventListener("DOMContentLoaded", () => {
      bindGuaranteeToggle("fiducie", "fiducie_pct");
      bindGuaranteeToggle("g1d", "g1d_pct");
      bindGuaranteeToggle("hyp1", "hyp1_pct");
      bindGuaranteeToggle("nantissement", "nantissement_pct");
      bindGuaranteeToggle("caution", "caution_eur");
    });

    // TYPE PROJET : MDB / LDT
    document.getElementById("projectType").addEventListener("change", () => {
      const type = document.getElementById("projectType").value;
      const sectionLDT = document.getElementById("sectionLDT");
      sectionLDT.style.display = (type === "LDT") ? "block" : "none";
    });

    // EXPORT CSV
    function exportCSV() {
      let rows = [["Projet", "LTV NET", "Risque", "Tickets", "Mise"]];
      document.querySelectorAll("#tableProjets tr").forEach(tr => {
        const projet = tr.querySelector("td:nth-child(1)")?.innerText || "";
        const ltv = tr.querySelector("td:nth-child(2)")?.innerText || "";
        const risque = tr.querySelector("td:nth-child(3)")?.innerText || "";
        const ticketsCell = tr.querySelector("td:nth-child(4)");
        let tickets = "";
        let mise = "";
        if (ticketsCell) {
          const main = ticketsCell.querySelector(".tickets-main");
          const miseSpan = ticketsCell.querySelector(".tickets-mise");
          tickets = main ? main.innerText : "";
          mise = miseSpan ? miseSpan.innerText.replace("Mise : ", "") : "";
        }
        if (projet) rows.push([projet, ltv, risque, tickets, mise]);
      });
      let csv = rows.map(r => r.join(";")).join("\n");
      let blob = new Blob([csv], { type: "text/csv" });
      let url = URL.createObjectURL(blob);
      let a = document.createElement("a");
      a.href = url;
      a.download = "projets_audites.csv";
      a.click();
    }
  </script>

  <script type="module">
    import { runLPBEngine } from "./engine/engine.js";

    function readNumber(id) {
      const el = document.getElementById(id);
      if (!el) return null;
      const v = parseFloat((el.value || "").replace(",", "."));
      return isNaN(v) ? null : v;
    }
    function readCheckbox(id) {
      const el = document.getElementById(id);
      return el ? !!el.checked : false;
    }

    function formatTickets(ticketIA) {
      if (!ticketIA || !ticketIA.plage) return "-";
      const { min, max } = ticketIA.plage;
      if (min == null && max == null) return "-";
      if (min == null) return `0–${max} €`;
      if (max == null) return `${min} €+`;
      return `${min}–${max} €`;
    }

    function deriveRisqueLabel(score, meta) {
      if (meta && meta.securiteGlobale) {
        const s = meta.securiteGlobale;
        if (s === "forte") return "PREMIUM";
        if (s === "moyenne") return "SAFE";
        if (s === "faible") return "TENDU";
        return "CRITIQUE";
      }
      if (score >= 80) return "PREMIUM";
      if (score >= 60) return "SAFE";
      if (score >= 40) return "TENDU";
      return "CRITIQUE";
    }

    window.runEngine = function() {
      const type = document.getElementById("projectType").value || "MDB";
      const nomProjet = (document.getElementById("nomProjet").value || "").trim() || "Projet sans nom";

      const valeurs = {
        LTV: readNumber("ltv"),
        LTA: readNumber("lta"),
        LTC: readNumber("ltc"),
        marge: readNumber("marge"),
        precomm: readNumber("precomm"),
        liquidite: readNumber("liq"),
        mise: readNumber("mise")
      };

      const garanties = {
        fiducie: readCheckbox("fiducie"),
        fiducie_pct: readNumber("fiducie_pct"),
        g1d: readCheckbox("g1d"),
        g1d_pct: readNumber("g1d_pct"),
        hyp1: readCheckbox("hyp1"),
        hyp1_pct: readNumber("hyp1_pct"),
        nantissement: readCheckbox("nantissement"),
        nantissement_pct: readNumber("nantissement_pct"),
        caution: readCheckbox("caution"),
        caution_eur: readNumber("caution_eur")
      };

      const ldt = {
        montant: readNumber("ldt_montant"),
        duree: readNumber("ldt_duree"),
        taux: readNumber("ldt_taux"),
        capacite: readNumber("ldt_capacite")
      };

      const input = {
        type,
        besoin: null,
        valeurs,
        garanties,
        ldt
      };

      const result = runLPBEngine(input);
      const { ratios, score, diagnostic, ticketIA, meta } = result;

      const ltvNet = (ratios && ratios.LTV_net != null)
        ? `${ratios.LTV_net.toFixed(1)}%`
        : (valeurs.LTV != null ? `${valeurs.LTV.toFixed(1)}%` : "-");

      const risque = deriveRisqueLabel(score, meta);
      const tickets = formatTickets(ticketIA);
      const mise = valeurs.mise != null ? `${valeurs.mise.toLocaleString("fr-FR")} €` : "-";

      const tableBody = document.getElementById("tableProjets");
      const tr = document.createElement("tr");

      const tdProjet = document.createElement("td");
      tdProjet.textContent = `${nomProjet} (${type})`;

      const tdLtv = document.createElement("td");
      tdLtv.textContent = ltvNet;

      const tdRisque = document.createElement("td");
      tdRisque.textContent = risque;
      tdRisque.classList.add(
        risque === "PREMIUM" ? "risque-premium" :
        risque === "SAFE" ? "risque-safe" :
        risque === "TENDU" ? "risque-tendu" : "risque-critique"
      );

      const tdTickets = document.createElement("td");
      tdTickets.classList.add("tickets-cell");
      const spanTickets = document.createElement("span");
      spanTickets.classList.add("tickets-main");
      spanTickets.textContent = tickets;
      const spanMise = document.createElement("span");
      spanMise.classList.add("tickets-mise");
      spanMise.textContent = `Mise : ${mise}`;
      tdTickets.appendChild(spanTickets);
      tdTickets.appendChild(spanMise);

      tr.appendChild(tdProjet);
      tr.appendChild(tdLtv);
      tr.appendChild(tdRisque);
      tr.appendChild(tdTickets);
      tableBody.appendChild(tr);

      // Score portefeuille (moyenne simple des scores)
      const rows = tableBody.querySelectorAll("tr");
      let totalScore = 0;
      rows.forEach(() => { totalScore += score; });
      const avgScore = rows.length ? (totalScore / rows.length) : 0;
      document.getElementById("scorePortefeuille").textContent = `${avgScore.toFixed(0)}/100`;

      // Total investi : somme des mises
      let totalMise = 0;
      rows.forEach(() => {
        if (valeurs.mise != null) totalMise += valeurs.mise;
      });
      document.getElementById("totalInvesti").textContent = `${totalMise.toLocaleString("fr-FR")} €`;
    };
  </script>
</body>
</html>
